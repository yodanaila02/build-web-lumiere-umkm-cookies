# =====================================================
# FILE: .env.example  (salin menjadi .env lalu isi nilainya)
# JANGAN commit file .env yang berisi nilai asli!
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lumiere_cookies
DB_USER=root
DB_PASS=

# Secret untuk keamanan (boleh acak)
APP_SECRET=ubah-dengan-string-acak-panjang

# Base path aplikasi (kosongkan jika di root domain).
# Contoh jika diakses di http://localhost/sesuai nama folder anda/public -> APP_BASE=/lumiere/public
APP_BASE=
